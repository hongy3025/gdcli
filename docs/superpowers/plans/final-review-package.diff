+
+    let meta = format!(
+        r#"{{"http_port":{},"lsp_port":6005,"pid":{},"gdapi_version":"0.2.0"}}"#,
+        server.port(),
+        std::process::id()
+    );
+    let dir = setup_fake_project(&meta);
+
+    let output = Command::cargo_bin("gdcli")
+        .unwrap()
+        .args([
+            "--json",
+            "exec",
+            "commands",
+            "--project",
